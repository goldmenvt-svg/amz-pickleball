rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == "goldmenvt@gmail.com";
    }

    // TD-03: đăng ký công khai KHÔNG cần đăng nhập (form dat-san/giai-dau),
    // nên thay `create: if true` bằng validate shape để chặn ghi rác/lạm quyền.
    // Người đăng ký công khai chỉ được tạo đúng field, luôn ở trạng thái 'pending'.
    function isValidPublicRegistration() {
      let d = request.resource.data;
      return d.keys().hasOnly([
               'event_id','player_1_name','player_1_phone','player_1_email','player_1_id',
               'player_2_name','player_2_phone','player_2_id',
               'status','payment_status','checkin_status','seed_number','source','created_at'
             ])
          && d.event_id is string && d.event_id.size() > 0 && d.event_id.size() < 200
          && d.player_1_name is string && d.player_1_name.size() > 0 && d.player_1_name.size() < 100
          && d.player_1_phone is string && d.player_1_phone.size() > 0 && d.player_1_phone.size() < 20
          && d.status == 'pending'
          && d.payment_status == 'pending'
          && d.checkin_status == 'pending'
          && d.seed_number == 0
          && d.source == 'public'
          && d.player_1_id == null
          && d.player_2_id == null
          && (d.player_1_email == null || (d.player_1_email is string && d.player_1_email.size() < 150))
          && (d.player_2_name  == null || (d.player_2_name  is string && d.player_2_name.size()  < 100))
          && (d.player_2_phone == null || (d.player_2_phone is string && d.player_2_phone.size() < 20))
          && d.created_at is string && d.created_at.size() < 40;
    }

    match /videos/{videoId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /config/{configId} {
      allow read, write: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrations/{regId} {
      allow create: if isAdmin() || isValidPublicRegistration();
      allow read, update, delete: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TD-04: bổ sung rule cho các collection app-nextjs / schema dùng.
    // courts hiển thị công khai (trang đặt sân đọc để render).
    match /courts/{courtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Các collection dưới CHƯA có luồng client hoàn chỉnh (đặt sân đang mock,
    // app chưa có đăng nhập). Tạm admin-only (fail-closed, an toàn). Khi triển khai
    // đặt sân/hội viên + mô hình đăng nhập sẽ mở rule owner-based (request.auth.uid)
    // — xem docs/design/DESIGN-firestore-rules.md. payments/elo_history append-only.
    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
    }
    match /payments/{paymentId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    match /members/{uid} {
      allow read, write: if isAdmin();
    }
    match /users/{uid} {
      allow read, write: if isAdmin();
    }
    match /elo_history/{id} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
